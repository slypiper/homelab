#!/usr/bin/env bash

# ==============================================================================
# 1. Bashrc Setup
# ==============================================================================

# Edit/install bashrc
alias ebrc='nvim /data/linux/bashrc && echo "Run \"cpbrc\" to install changes."'
alias cpbrc='/usr/bin/cp -f /data/linux/bashrc ~/.bashrc && source ~/.bashrc 1> /dev/null'


# ==============================================================================
# 2. Environment Variables
# ==============================================================================

# XDG Base Directory Specification
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_STATE_HOME="$HOME/.local/state"
export XDG_CACHE_HOME="$HOME/.cache"

# System Paths and Configuration
export PATH="$PATH:~/bin:/usr/local/bin:~/.local/bin:/data/bin"
export KUBECONFIG="/data/linux/config/kube"
export ANSIBLE_INVENTORY="/data/ansible/inventory.ini"

# Bash History Configuration
export HISTFILESIZE=10000
export HISTSIZE=500
export HISTTIMEFORMAT="%F %T " # Add timestamp to history
export HISTCONTROL=erasedups:ignoredups:ignorespace

# ==============================================================================
# 3. External Sources & Aliases 
# ==============================================================================

# Source global definitions
if [ -f /etc/bashrc ]; then
  . /etc/bashrc
fi

# Source dynamic alias files
if [ -d "/data/aliases" ]; then
  for f in /data/aliases/*; do
    [ -f "$f" ] && source "$f"
  done
fi

# Source secrets (API keys, etc.)
if [ -f "/data/linux/config/secrets/env.sh" ]; then
  source "/data/linux/config/secrets/env.sh"
fi

# Setup ripgrep if installed
if command -v rg &> /dev/null; then
    alias grep='rg'
fi

# Setup bat/batcat if installed
if command -v bat &>/dev/null; then
  alias cat='bat'
  alias ccat='/usr/bin/cat'
elif command -v batcat &>/dev/null; then
  alias cat='batcat'
  alias ccat='/usr/bin/cat'
fi

# ==============================================================================
# 4. Interactive Shell Configuration
# ==============================================================================

if [[ $- == *i* ]]; then

  # Terminal Welcome Graphic
  if command -v fastfetch &>/dev/null; then
    fastfetch --logo-color-1 yellow --logo-color-2 magenta
  fi

  # Window and History Behavior
  shopt -s checkwinsize
  shopt -s histappend
  PROMPT_COMMAND='history -a'

  # Keyboard Bindings and Tab Completion
  bind "set bell-style visible"
  bind "set completion-ignore-case on"
  bind "set show-all-if-ambiguous On"
  bind '"\C-f":"zi\n"'                 # Quick search with zoxide

  # CLI Integrations
  eval "$(starship init bash)"
  eval "$(zoxide init bash)"

  # Bash Programmable Completion
  if [ -f /usr/share/bash-completion/bash_completion ]; then
    . /usr/share/bash-completion/bash_completion
  elif [ -f /etc/bash_completion ]; then
    . /etc/bash_completion
  fi

  # Fuzzy Finder (fzf) bash completion and options
  if command -v fzf &>/dev/null; then
    if grep -q '^ID=ubuntu' /etc/os-release; then
      if [[ -f "/data/linux/config/fzf.bash" ]]; then
        source "/data/linux/config/fzf.bash"
      fi
    else
      # Fallback eval for versions like Arch
      eval "$(fzf --bash)"
    fi
    export FZF_DEFAULT_OPTS='--layout=reverse --border=bold --border=rounded --margin=3% --color=dark'
    export FZF_COMPLETION_TRIGGER='~~'
  fi

fi